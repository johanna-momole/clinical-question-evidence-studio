# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=false

# ── LLM Provider (leave unset to run in deterministic demo mode) ─────────────
# Options: anthropic | openai
LLM_PROVIDER=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_MODEL=claude-sonnet-4-6
DEMO_MODE=true

# ── FastAPI ───────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Evidence Sources (all optional — offline fixtures used when absent) ───────
PUBMED_API_KEY=
NCBI_BASE_URL=https://eutils.ncbi.nlm.nih.gov/entrez/eutils
CLINICALTRIALS_BASE_URL=https://clinicaltrials.gov/api/v2
RXNORM_BASE_URL=https://rxnav.nlm.nih.gov/REST

# ── Storage ───────────────────────────────────────────────────────────────────
DATA_DIR=data
FIXTURES_DIR=data/fixtures
CACHE_DIR=.cache

# ── Quality Assurance ─────────────────────────────────────────────────────────
MAX_EVIDENCE_AGE_DAYS=1825
